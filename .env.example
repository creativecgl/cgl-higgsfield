# Higgsfield Unlimited MCP credentials
# Copy this file to .env and fill in your values.

# From Chrome: DevTools → Application → Cookies → higgsfield.ai → __client
HIGGSFIELD_CLERK_COOKIE=

# From Chrome console: window.Clerk.session.id
HIGGSFIELD_SESSION_ID=

# Optional overrides
HIGGSFIELD_MAX_CONCURRENT=4
HIGGSFIELD_DEFAULT_MODEL=nano_banana_2
HIGGSFIELD_DEFAULT_RESOLUTION=2k
HIGGSFIELD_OUTPUT_DIR=./higgsfield_output
HIGGSFIELD_LOG_LEVEL=INFO
